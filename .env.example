# =============================================================================
# Aegis AI - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All secrets are optional at startup - the Setup Wizard configures them at runtime.
#
#   cp .env.example .env
# =============================================================================

# Application port (default: 15000)
AEGIS_PORT=15000

# 32-byte base64-encoded Fernet encryption key
# Auto-generated at runtime if not provided.
# Generate one: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# CrowdStrike AIDR Token (optional - can be configured via Setup Wizard)
# CS_AIDR_TOKEN=

# CrowdStrike AIDR Base URL Template (used by MCP proxy)
# CS_AIDR_BASE_URL_TEMPLATE=https://api.crowdstrike.com/aidr/{SERVICE_NAME}
